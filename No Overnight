            "Duty_h":         round(res["duty"]  / 60, 2),
            "Feasible":       "Yes" if res["feasible"] else "No",
            "Order_IDs":      "0 → " + " → ".join(str(o) for o in route) + " → 0",
            "Route_Sequence": route_seq_full(route),
        })

