def route_seq_full(route):
    parts = ["0 (DC)"]
    for oid in route:
        city  = zipid_to_city.get(order_dict[oid]["zip_id"], "?")
        state = zipid_to_state.get(order_dict[oid]["zip_id"], "?")
        parts.append(f"{oid} ({city},{state})")
    parts.append("0 (DC)")
    return " → ".join(parts)

csv_rows = []
for day in days:
    for ri, route in enumerate(all_routes[day]):
        res  = simulate(route)
        cube = sum(order_dict[o]["cube"] for o in route)
        csv_rows.append({
            "Route":          f"{day} R{ri+1}",
            "Day":            day,
            "Route_Num":      ri + 1,
            "Stops":          len(route),
            "Miles":          round(res["miles"], 1),
            "Cube_ft3":       cube,
            "Van_Capacity":   van_capacity,
            "Util_Pct":       round(cube / van_capacity * 100, 1),
            "Overnight":      "No",
