# ── helper: compute total drive/duty across BOTH days for overnight routes ────
def simulate_full(route):
    # tracks total drive and duty across the entire route including both days
    if not route:
        return {"feasible": True, "miles": 0.0, "overnight": False,
                "drive_d1": 0.0, "duty_d1": 0.0,
                "drive_d2": 0.0, "duty_d2": 0.0,
                "total_drive": 0.0, "total_duty": 0.0}
    clock     = window_open - drive_mins(depot_id, order_dict[route[0]]["zip_id"])
    loc       = depot_id
    miles     = drive_acc = duty_acc = 0.0
    drive_d1  = duty_d1 = 0.0
    overnight = False

    for oid in route:
        dest    = order_dict[oid]["zip_id"]
        leg_mi  = get_dist(loc, dest)
        leg_min = drive_mins(loc, dest)
        ul      = unload_mins(order_dict[oid]["cube"])
        d_left  = max_driving - drive_acc
        dy_left = max_duty    - duty_acc

        if leg_min > d_left or leg_min > dy_left:
            drv = min(d_left, dy_left)
            drive_d1 += drive_acc + drv
            duty_d1  += duty_acc  + drv
            clock    += drv + break_time
            miles    += (drv / 60) * driving_speed
            drive_acc = duty_acc = 0.0
            overnight = True
            if clock < window_open + 1440: clock = window_open + 1440
            rem_mi  = leg_mi - (drv / 60) * driving_speed
            rem_min = (rem_mi / driving_speed) * 60
            clock += rem_min; drive_acc += rem_min; duty_acc += rem_min
            miles += rem_mi; loc = dest
            if clock > window_close + 1440:
                return {"feasible": False, "miles": miles, "overnight": overnight}
            clock += ul; duty_acc += ul; continue

        clock += leg_min; drive_acc += leg_min; duty_acc += leg_min
        miles += leg_mi; loc = dest
        if clock > window_close + (1440 if overnight else 0):
            return {"feasible": False, "miles": miles, "overnight": overnight}
        clock += ul; duty_acc += ul

    ret_mi  = get_dist(loc, depot_id)
    ret_min = drive_mins(loc, depot_id)
    if drive_acc + ret_min > max_driving or duty_acc + ret_min > max_duty:
        return {"feasible": False, "miles": miles, "overnight": overnight}
    miles     += ret_mi
    drive_acc += ret_min; duty_acc += ret_min

    if overnight:
        drive_d2 = drive_acc; duty_d2 = duty_acc
    else:
        drive_d1 = drive_acc; duty_d1 = duty_acc
        drive_d2 = duty_d2 = 0.0

    return {"feasible": True, "miles": miles, "overnight": overnight,
            "drive_d1": drive_d1, "duty_d1": duty_d1,
            "drive_d2": drive_d2, "duty_d2": duty_d2,
            "total_drive": drive_d1 + drive_d2,
            "total_duty":  duty_d1  + duty_d2}


